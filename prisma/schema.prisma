generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(uuid())
  mobile            String           @unique
  name              String?
  address           String?
  preferredLanguage String           @default("en")
  accessibilityMode String           @default("none")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  services          ServiceRequest[]
}

model OTPSession {
  id        String   @id @default(uuid())
  mobile    String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mobile])
}

model ServiceRequest {
  id          String   @id @default(uuid())
  userId      String
  serviceType String   // ELECTRICITY, GAS, WATER, WASTE
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, RESOLVED
  details     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model DocumentToken {
  id          String   @id @default(uuid())
  token       String   @unique
  expiresAt   DateTime
  used        Boolean  @default(false)
  fileName      String?
  fileSize      Int?
  mimeType      String?
  cloudinaryUrl String?
  cloudinaryId  String?
  serviceType   String?  // 'electricity' | 'gas' | 'water' | 'complaint'
  uploadedAt    DateTime @default(now())
}

model UserConversationState {
  id              String   @id @default(uuid())
  phoneNumber     String   @unique
  language        String   @default("en")
  currentStep     String   @default("LANGUAGE_SELECT")
  department      String?
  issueType       String?
  description     String?
  lastMessageAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Complaint {
  id              String   @id @default(uuid())
  phoneNumber     String
  department      String
  issueType       String
  description     String   @db.Text
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Document {
  id              String   @id @default(uuid())
  phoneNumber     String
  service         String
  documentType    String
  fileName        String
  fileUrl         String
  mediaId         String?
  mediaType       String?  // image, document, etc.
  uploadedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
